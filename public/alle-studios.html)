<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Alle Studios – VenueMap.ch</title>
<link rel="preconnect" href="https://fonts.googleapis.com"><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet">
<style>
:root{--bg:#09080D;--bg2:#0F0E16;--bg3:#161520;--sf:rgba(22,21,32,.7);--sf2:rgba(30,29,42,.9);--bdr:rgba(255,255,255,.06);--bdr2:rgba(255,255,255,.1);--tx:#F4F2F7;--tx2:#9B97A8;--tx3:#5E5A6E;--ac:#C8926A;--ac2:#DDAA82;--ac3:#E8BE9A;--acl:rgba(200,146,106,.08);--grn:#6BAD8E;--f:'Inter',system-ui,sans-serif;--fs:'Playfair Display',Georgia,serif;--r:14px}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}html{scroll-behavior:smooth}body{font-family:var(--f);background:var(--bg);color:var(--tx);-webkit-font-smoothing:antialiased;overflow-x:hidden}a{color:inherit;text-decoration:none}button{font-family:var(--f);cursor:pointer}.ctn{max-width:1100px;margin:0 auto;padding:0 20px}@media(min-width:768px){.ctn{padding:0 40px}}
.bg-mesh{position:fixed;inset:0;z-index:0;overflow:hidden}.bg-orb{position:absolute;border-radius:50%;filter:blur(120px);opacity:.1;animation:orbF 28s ease-in-out infinite}.o1{width:600px;height:600px;background:radial-gradient(circle,#C8926A,transparent 70%);top:-15%;right:-10%}.o2{width:400px;height:400px;background:radial-gradient(circle,#6B5EC8,transparent 70%);bottom:-10%;left:-8%;animation-delay:-8s}@keyframes orbF{0%,100%{transform:translate(0,0)}25%{transform:translate(40px,-60px)}50%{transform:translate(-30px,40px)}75%{transform:translate(20px,50px)}}
.bg-grain{position:fixed;inset:0;z-index:1;pointer-events:none;opacity:.022;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");background-size:200px}
.bg-grid{position:fixed;inset:0;z-index:1;pointer-events:none;opacity:.02;background-image:linear-gradient(rgba(255,255,255,.07) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.07) 1px,transparent 1px);background-size:80px 80px}
.pg{position:relative;z-index:2}@media(max-width:767px){.pg{padding-bottom:62px}}
.glass{background:var(--sf);backdrop-filter:blur(16px);border:1px solid var(--bdr);border-radius:var(--r);transition:all .4s cubic-bezier(.16,1,.3,1)}.glass:hover{border-color:var(--bdr2)}
.rv{opacity:0;transform:translateY(24px);transition:opacity .9s cubic-bezier(.16,1,.3,1),transform .9s cubic-bezier(.16,1,.3,1)}.rv.v{opacity:1;transform:none}.d1{transition-delay:.08s}.d2{transition-delay:.16s}.d3{transition-delay:.24s}
header{position:fixed;top:0;left:0;right:0;z-index:100;height:60px}.hd-bg{position:absolute;inset:0;background:rgba(9,8,13,.5);backdrop-filter:blur(30px)saturate(1.4);border-bottom:1px solid var(--bdr)}.hdi{max-width:1100px;margin:0 auto;padding:0 20px;height:100%;display:flex;align-items:center;justify-content:space-between;position:relative;z-index:1}@media(min-width:768px){.hdi{padding:0 40px}}.logo{font-family:var(--fs);font-size:1.15rem;font-weight:500;display:flex;align-items:center;gap:8px}.logo-m{width:28px;height:28px;border-radius:8px;background:linear-gradient(135deg,var(--ac),#A07050);display:flex;align-items:center;justify-content:center}.logo-m svg{width:12px;height:12px;stroke:#fff;fill:none;stroke-width:2}nav.dk{display:none;align-items:center;gap:2px}@media(min-width:768px){nav.dk{display:flex}}.nk{font-size:.8rem;color:var(--tx3);padding:7px 14px;border-radius:8px;transition:color .2s}.nk:hover{color:var(--tx2)}.nk.a{color:var(--tx)}.sep{width:1px;height:14px;background:var(--bdr);margin:0 8px}.lng{font-size:.68rem;color:var(--tx3);font-weight:500;letter-spacing:.06em}.lng b{color:var(--tx2)}.hcta{height:34px;padding:0 18px;background:linear-gradient(135deg,var(--ac),var(--ac2));color:var(--bg);font-size:.74rem;font-weight:600;border:none;border-radius:8px;display:none;align-items:center;transition:all .2s;box-shadow:0 2px 12px rgba(200,146,106,.2)}@media(min-width:768px){.hcta{display:inline-flex}}.burg{display:flex;flex-direction:column;gap:4.5px;background:none;border:none;padding:8px}.burg span{width:18px;height:1.5px;background:var(--tx3);border-radius:2px}@media(min-width:768px){.burg{display:none}}.mobnav{display:none;position:fixed;inset:0;z-index:99;background:rgba(9,8,13,.97);backdrop-filter:blur(24px);flex-direction:column;align-items:center;justify-content:center;gap:36px}.mobnav.open{display:flex}.mobnav a{font-size:1.2rem;color:var(--tx2);font-weight:300}.mobnav .x{position:absolute;top:18px;right:20px;background:none;border:none;font-size:1.2rem;color:var(--tx3)}
.bnav{display:none;position:fixed;bottom:0;left:0;right:0;z-index:100;background:rgba(9,8,13,.88);backdrop-filter:blur(24px);border-top:1px solid var(--bdr);padding:5px 0 env(safe-area-inset-bottom,5px)}@media(max-width:767px){.bnav{display:flex}}.bnav-i{display:flex;justify-content:space-around;max-width:340px;margin:0 auto;width:100%}.bna{display:flex;flex-direction:column;align-items:center;gap:2px;padding:6px 10px;color:var(--tx3);font-size:.52rem;font-weight:500;text-decoration:none}.bna.a{color:var(--ac)}.bna svg{width:18px;height:18px;stroke:currentColor;fill:none;stroke-width:1.5}
.page-hero{padding:80px 0 24px}@media(min-width:768px){.page-hero{padding:96px 0 32px}}
.page-hero h1{font-family:var(--fs);font-size:clamp(1.8rem,4vw,2.6rem);font-weight:400;letter-spacing:-.02em;margin-bottom:4px}
.page-hero p{font-size:.88rem;color:var(--tx2);font-weight:300}
.filters{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:24px}
.filters input,.filters select{height:42px;padding:0 14px;background:rgba(255,255,255,.04);border:1px solid var(--bdr);border-radius:10px;font-family:var(--f);font-size:.82rem;color:var(--tx);outline:none;transition:border-color .2s}.filters input:focus,.filters select:focus{border-color:rgba(200,146,106,.4)}.filters input::placeholder{color:var(--tx3)}.filters input{flex:1;min-width:180px}.filters select{min-width:140px;appearance:none;background-image:url("data:image/svg+xml,%3Csvg width='12' height='8' viewBox='0 0 12 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1.5L6 6.5L11 1.5' stroke='%235E5A6E' stroke-width='1.5' stroke-linecap='round'/%3E%3C/svg%3E");background-repeat:no-repeat;background-position:right 12px center;padding-right:32px}.filters select option{background:#161520;color:#F4F2F7}
.count{font-size:.76rem;color:var(--tx3);margin-bottom:16px}
.studio-g{display:grid;gap:14px;padding-bottom:80px;grid-template-columns:1fr}@media(min-width:600px){.studio-g{grid-template-columns:repeat(2,1fr)}}@media(min-width:900px){.studio-g{grid-template-columns:repeat(3,1fr)}}
.sc{overflow:hidden;cursor:pointer;display:block;position:relative}.sc:hover{border-color:rgba(200,146,106,.15);box-shadow:0 12px 40px rgba(0,0,0,.25)}.sc-img{height:200px;background:var(--bg3);position:relative;display:flex;align-items:center;justify-content:center}.sc-img::before{content:'';position:absolute;inset:0;background:linear-gradient(180deg,transparent 40%,rgba(9,8,13,.7));z-index:1}.sc-img svg{width:28px;height:28px;stroke:var(--tx3);fill:none;stroke-width:1;opacity:.2}.sc-cat{position:absolute;top:12px;left:12px;font-size:.58rem;font-weight:600;padding:4px 10px;border-radius:6px;background:rgba(9,8,13,.6);backdrop-filter:blur(8px);color:var(--tx2);letter-spacing:.04em;text-transform:uppercase;z-index:2;border:1px solid var(--bdr)}.sc-b{padding:18px 20px}.sc-n{font-family:var(--fs);font-size:1.05rem;font-weight:400;margin-bottom:5px;display:flex;align-items:center;gap:8px}.sc-v{display:inline-flex;align-items:center;gap:3px;font-size:.56rem;font-weight:600;color:var(--grn);background:rgba(107,173,142,.08);padding:2px 7px;border-radius:4px;border:1px solid rgba(107,173,142,.15)}.sc-v svg{width:8px;height:8px;stroke:var(--grn);fill:none;stroke-width:2.5}.sc-loc{font-size:.74rem;color:var(--tx3);display:flex;align-items:center;gap:4px}.sc-loc svg{width:10px;height:10px;stroke:var(--tx3);fill:none;stroke-width:2}
.empty{text-align:center;padding:60px 20px;color:var(--tx3);font-size:.88rem}
footer{border-top:1px solid var(--bdr);padding:28px 0}.foot{display:flex;flex-direction:column;gap:12px;align-items:center;text-align:center}@media(min-width:768px){.foot{flex-direction:row;justify-content:space-between}}.foot-l{display:flex;gap:18px;font-size:.74rem;color:var(--tx3)}.foot-l a:hover{color:var(--tx2)}.foot-18{font-size:.62rem;color:var(--tx3);opacity:.35}
</style>
</head>
<body>
<div class="bg-mesh"><div class="bg-orb o1"></div><div class="bg-orb o2"></div></div><div class="bg-grain"></div><div class="bg-grid"></div>
<div class="pg">
<header><div class="hd-bg"></div><div class="hdi"><a href="/" class="logo"><div class="logo-m"><svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7Z"/></svg></div>VenueMap</a><nav class="dk"><a href="/" class="nk">Städte</a><a href="/alle-studios" class="nk a">Alle Studios</a><a href="/studios" class="nk">Für Studios</a><div class="sep"></div><span class="lng"><b>DE</b> / FR</span><div class="sep"></div><a href="/studios" class="hcta">Studio eintragen</a></nav><button class="burg" onclick="document.getElementById('mn').classList.add('open')"><span></span><span></span><span></span></button></div></header>
<div id="mn" class="mobnav"><button class="x" onclick="this.parentElement.classList.remove('open')">✕</button><a href="/">Städte</a><a href="/alle-studios">Alle Studios</a><a href="/studios">Für Studios</a></div>

<section class="page-hero"><div class="ctn">
  <h1 class="rv">Alle Studios</h1>
  <p class="rv d1" id="subtitle">Lade…</p>
</div></section>

<section><div class="ctn">
  <div class="filters rv d2">
    <input type="text" id="fSearch" placeholder="Studio suchen…" oninput="applyFilters()">
    <select id="fCity" onchange="applyFilters()"><option value="">Alle Städte</option></select>
    <select id="fKat" onchange="applyFilters()"><option value="">Alle Kategorien</option></select>
  </div>
  <div class="count rv d2" id="countText"></div>
  <div class="studio-g" id="studioGrid"><div class="empty">Lade Studios…</div></div>
</div></section>

<footer><div class="ctn foot"><div class="foot-l"><a href="#">Impressum</a><a href="#">Datenschutz</a><a href="#">Kontakt</a></div><span class="foot-18">Nur für Personen ab 18 Jahren.</span></div></footer>
</div>
<nav class="bnav"><div class="bnav-i"><a href="/" class="bna"><svg viewBox="0 0 24 24"><polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"/></svg>Städte</a><a href="#" class="bna"><svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>Suche</a><a href="/alle-studios" class="bna a"><svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>Studios</a><a href="#" class="bna"><svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>Login</a></div></nav>

<script>
const SB='https://undrlwlxcsrayldbxepd.supabase.co/rest/v1/';
const KEY='eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InVuZHJsd2x4Y3NyYXlsZGJ4ZXBkIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzA5OTkyMDMsImV4cCI6MjA4NjU3NTIwM30.7-U3lFqu5jyrg-CeQwQyJrUmZflC3PqmhytSfRk7KbI';
async function q(path){const r=await fetch(SB+path,{headers:{'apikey':KEY}});return r.json();}

const imgSvg='<svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>';
const pinSvg='<svg viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7Z"/></svg>';
const checkSvg='<svg viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg>';

let allStudios=[], allCities=[], allKats=[];

function renderCard(s, i){
  const kat = s.kategorien ? s.kategorien.name : '';
  const city = s.staedte ? s.staedte.name : '';
  const verified = s.is_verified ? '<span class="sc-v">'+checkSvg+'Geprüft</span>' : '';
  return '<a href="/detail.html?id='+s.id+'" class="glass sc rv d'+(i%4+1)+'"><div class="sc-img">'+imgSvg+'<span class="sc-cat">'+kat+'</span></div><div class="sc-b"><div class="sc-n">'+s.name+' '+verified+'</div><div class="sc-loc">'+pinSvg+city+'</div></div></a>';
}

function applyFilters(){
  const search = (document.getElementById('fSearch').value||'').toLowerCase();
  const cityId = document.getElementById('fCity').value;
  const katId = document.getElementById('fKat').value;

  let filtered = allStudios;
  if(search) filtered = filtered.filter(s => s.name.toLowerCase().includes(search) || (s.staedte && s.staedte.name.toLowerCase().includes(search)));
  if(cityId) filtered = filtered.filter(s => s.stadt_id === cityId);
  if(katId) filtered = filtered.filter(s => s.kategorie_id === katId);

  document.getElementById('countText').textContent = filtered.length + ' Studios gefunden';
  document.getElementById('studioGrid').innerHTML = filtered.length
    ? filtered.map((s,i) => renderCard(s,i)).join('')
    : '<div class="empty">Keine Studios gefunden.</div>';

  document.querySelectorAll('.rv:not(.v)').forEach(function(el){
    new IntersectionObserver(function(e){if(e[0].isIntersecting)el.classList.add('v')},{threshold:.08,rootMargin:'0px 0px -40px 0px'}).observe(el);
  });
}

async function init(){
  try{
    const [studios, cities, kats] = await Promise.all([
      q('studios?status=eq.approved&order=is_pro.desc,sort_order,created_at.desc&select=*,kategorien(name),staedte(name)'),
      q('staedte?is_active=eq.true&order=name'),
      q('kategorien?order=sort_order')
    ]);

    allStudios = studios;
    allCities = cities;
    allKats = kats;

    document.getElementById('subtitle').textContent = studios.length + ' geprüfte Studios in der ganzen Schweiz';

    // Populate filters
    const citySelect = document.getElementById('fCity');
    cities.forEach(c => { const o=document.createElement('option'); o.value=c.id; o.textContent=c.name; citySelect.appendChild(o); });

    const katSelect = document.getElementById('fKat');
    kats.forEach(k => { const o=document.createElement('option'); o.value=k.id; o.textContent=k.name; katSelect.appendChild(o); });

    applyFilters();
  } catch(e){ console.error(e); }
}

document.querySelectorAll('.rv').forEach(function(el){new IntersectionObserver(function(e){if(e[0].isIntersecting)el.classList.add('v')},{threshold:.08,rootMargin:'0px 0px -40px 0px'}).observe(el)});
window.addEventListener('scroll',function(){var s=window.scrollY;document.querySelectorAll('.bg-orb').forEach(function(o,i){o.style.transform='translateY('+s*(.02+i*.008)+'px)'})},{passive:true});
init();
</script>
</body>
</html>
